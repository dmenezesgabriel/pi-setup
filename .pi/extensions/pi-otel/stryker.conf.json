{
  "$schema": "https://stryker-mutator.io/schema/stryker-schema.json",
  "mutate": [
    "src/core/**/*.ts",
    "src/index.ts",
    "src/adapters/mlflow/**/*.ts",
    "src/adapters/loader.ts",
    "src/core/*.ts",
    "src/adapters/types.ts"
  ],
  "mutator": "typescript",
  "packageManager": "npm",
  "testRunner": "vitest",
  "coverageAnalysis": "off",
  "reporters": ["clear-text", "progress", "html"],
  "concurrency": 2,
  "thresholds": { "high": 85, "low": 60, "break": 80 }
}
