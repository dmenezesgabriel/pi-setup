{
  "name": "pi-otel-mlflow",
  "version": "0.1.0",
  "description": "pi extension: OpenTelemetry -> MLflow tracing (OTLP/HTTP direct to MLflow server)",
  "type": "module",
  "dependencies": {
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/exporter-trace-otlp-proto": "0.57.2",
    "@opentelemetry/sdk-node": "0.57.2",
    "uuid": "9.0.1"
  },
  "devDependencies": {
    "@types/node": "20.19.39",
    "@types/uuid": "9.0.8",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "execa": "7.2.0",
    "get-port": "6.1.2",
    "prettier": "3.8.3",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "vitest": "1.6.1"
  },
  "scripts": {
    "test": "vitest",
    "test:unit": "vitest --run tests/unit",
    "test:integration": "RUN_INTEGRATION_TESTS=1 vitest --run tests/integration",
    "lint": "eslint 'src/**' 'tests/**' || true",
    "lint:fix": "eslint 'src/**' 'tests/**' --fix || true",
    "format": "prettier --write 'src/**/*.{ts,js,json,md}' || true",
    "format:check": "prettier --check 'src/**/*.{ts,js,json,md}' || true"
  }
}
